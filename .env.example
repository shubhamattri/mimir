# =============================================================================
# Mimir — Environment Configuration
# =============================================================================
# Copy to .env and adjust for your machine.
# This is the ONLY file that changes between machines.
# =============================================================================

# --- Ollama ---
# Native install (macOS with Metal GPU): http://host.docker.internal:11434
# Docker install (Linux/Cloud):          http://ollama:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Models ---
CHAT_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text

# --- Open WebUI ---
WEBUI_PORT=3000
WEBUI_SECRET_KEY=change-me-to-a-random-string

# --- Data paths (absolute) ---
DATA_DIR=./data

# --- Ollama in Docker (Linux only, uncomment if not running native) ---
# OLLAMA_IN_DOCKER=true
# OLLAMA_GPU=false
# NVIDIA_VISIBLE_DEVICES=all
